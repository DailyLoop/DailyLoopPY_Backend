# ============================================================
# News Aggregator Backend - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in with your actual values
# DO NOT commit .env to git (add it to .gitignore)

# ============================================================
# API Configuration
# ============================================================
API_HOST=localhost
API_PORT=8080

# ============================================================
# Database & Cache Configuration
# ============================================================
# Supabase (PostgreSQL Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard-settings-api

# Redis (Caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# External API Keys
# ============================================================
# News API (for fetching news articles)
# Get your key from: https://newsapi.org/
NEWS_API_KEY=your-newsapi-key-here

# Google Gemini API (for summarization)
# Get your key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ============================================================
# Logging Configuration
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Polling Worker Configuration
# ============================================================
# Interval (in minutes) for polling news for tracked stories
POLLING_INTERVAL=5
